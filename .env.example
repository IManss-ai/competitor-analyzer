# Rivalscope backend environment — copy to .env and fill in.
# Required: DATABASE_URL, OPENAI_API_KEY, APP_SECRET_KEY.

# --- Core ---
DATABASE_URL=sqlite:///./test.db
OPENAI_API_KEY=
SCRAPER_URL=
APP_SECRET_KEY=
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# --- Polar.sh billing (https://polar.sh/settings) ---
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SAAS_PRODUCT_ID=
POLAR_LOCAL_PRODUCT_ID=

# --- Resend transactional email (https://resend.com) ---
RESEND_API_KEY=
# FROM_EMAIL must be an address on a domain VERIFIED in Resend. The default
# (onboarding@resend.dev) only delivers to your own Resend account email, so
# magic-link logins to real users will NOT arrive in production.
FROM_EMAIL=onboarding@resend.dev
